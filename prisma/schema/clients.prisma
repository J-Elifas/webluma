model Client {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName   String
  contactPerson String
  email         String
  phone         String
  website       String?

  plan       ClientPlan
  monthlyFee Int

  startDate DateTime
  endDate   DateTime?
  notes     String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@index([userId])
  @@index([email])
  @@index([plan])
  @@index([startDate])
}

enum ClientPlan {
  starter    @map("STARTER")
  pro        @map("PRO")
  enterprise @map("ENTERPRISE")
}
