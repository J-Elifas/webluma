model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String   @db.VarChar(255)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients Client[]
}

enum Role {
  USER
  ADMIN
  GUEST
}
